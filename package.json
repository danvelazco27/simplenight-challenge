{
  "name": "simplenight-challenge",
  "version": "1.0.0",
  "description": "Simplenight Lead QA Take-Home Assignment - Playwright Testing Framework",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report html-report",
    "docker:build": "docker build -t simplenight-tests:latest .",
    "docker:test": "docker run --rm -e CI=true -e BASE_URL=https://wl.stg.simplenight.com -v $(pwd)/html-report:/app/html-report -v $(pwd)/junit-report:/app/junit-report -v $(pwd)/test-results:/app/test-results simplenight-tests:latest",
    "docker:test:headed": "docker run --rm -it -e CI=true -e BASE_URL=https://wl.stg.simplenight.com simplenight-tests:latest npm run test:headed",
    "docker:clean": "docker rmi simplenight-tests:latest"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "typescript",
    "simplenight"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  }
}
